{
  "manifest_version": 3,
  "name": "Linkedin Feed Blocker",
  "short_name": "Linkedin Blocker",
  "version": "1.1.0",
  "description": "Blocks the LinkedIn infinite feed from loading while leaving search and messaging intact.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Linkedin Feed Blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
